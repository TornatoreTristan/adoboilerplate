TZ=UTC
PORT=3333
HOST=localhost
LOG_LEVEL=info
APP_KEY=
APP_URL=http://localhost:3333
NODE_ENV=development
SESSION_DRIVER=cookie

# Database (matches docker-compose.yml postgres_dev)
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=dev
DB_PASSWORD=password
DB_DATABASE=bp_adonis6_dev

# Test database (matches docker-compose.yml postgres_test on port 5433)
TEST_DB_HOST=127.0.0.1
TEST_DB_PORT=5433
TEST_DB_USER=test
TEST_DB_PASSWORD=password
TEST_DB_DATABASE=bp_adonis6_test

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# REDIS_PASSWORD: obligatoire en production. Valeur par défaut du docker-compose : "changeme".
# Changer impérativement en production avec un mot de passe fort.
REDIS_PASSWORD=changeme

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email
# Driver: smtp | log
#  - smtp: send via any SMTP provider (Scaleway TEM, Mailgun, SendGrid, Brevo, ...)
#  - log : capture emails to logs without sending (dev / test)
# En développement, utiliser "log" pour capturer les emails sans les envoyer.
# En production, utiliser "smtp" avec un vrai provider SMTP.
MAIL_DRIVER=log

# Scaleway TEM SMTP defaults — replace user/password with credentials
# generated from the Scaleway console (Transactional Email > SMTP credentials).
MAIL_SMTP_HOST=smtp.tem.scw.cloud
MAIL_SMTP_PORT=587
MAIL_SMTP_SECURE=false
MAIL_SMTP_USER=
MAIL_SMTP_PASSWORD=

EMAIL_FROM_ADDRESS=
EMAIL_FROM_NAME=

UPLOADS_DISK=local
UPLOADS_MAX_SIZE=10485760
UPLOADS_ALLOWED_MIMES=image/*,application/pdf,text/*

# ClamAV Antivirus
CLAMAV_ENABLED=false
CLAMAV_SOCKET=/var/run/clamav/clamd.ctl
CLAMAV_HOST=localhost
CLAMAV_PORT=3310
# Set to true in production to reject uploads when ClamAV is unavailable
# (fail-closed) instead of silently letting them through.
CLAMAV_REQUIRED=false

# Password policy
# Set to false to skip the HIBP pwned-passwords API check at registration /
# reset. Local complexity rules (12+ chars, mixed case, digit, symbol) still
# apply.
PWNED_PASSWORD_CHECK_ENABLED=true

# Image Optimization
IMAGE_MAX_WIDTH=2048
IMAGE_MAX_HEIGHT=2048
IMAGE_QUALITY=80
IMAGE_CONVERT_TO_WEBP=false
IMAGE_STRIP_METADATA=true

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-1
AWS_BUCKET=
AWS_ENDPOINT=

# Stripe Connect (Niveau B - OAuth pour les organisations)
STRIPE_CONNECT_CLIENT_ID=
STRIPE_CONNECT_CLIENT_SECRET=
STRIPE_CONNECT_REDIRECT_URI=http://localhost:3333/admin/integrations/stripe/callback

# Stripe Application (Niveau A - Clés de l'app pour vendre des plans)
STRIPE_SECRET_KEY=
STRIPE_PUBLIC_KEY=
STRIPE_WEBHOOK_SECRET=

# Sentry Error Monitoring (Backend)
SENTRY_DSN=
SENTRY_ENABLED=true
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1

# Sentry (Frontend - exposed to browser via Vite)
VITE_SENTRY_DSN=
VITE_SENTRY_ENABLED=true
VITE_SENTRY_ENVIRONMENT=development
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1
VITE_SENTRY_REPLAY_SESSION_RATE=0.1

# CORS — comma-separated list of allowed origins (production)
# In development, all origins are allowed if this variable is not set.
# Example: CORS_ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ALLOWED_ORIGINS=http://localhost:3333

# Health check — secret token for the verbose /health/ready endpoint
# Usage: Authorization: Bearer <token>
# If not set, /health/ready returns a minimal { status } response.
HEALTH_CHECK_TOKEN=

# Days to retain audit logs (defaults to 90 if unset)
AUDIT_LOG_RETENTION_DAYS=90
