# .env.test
SESSION_DRIVER=memory
NODE_ENV=test

# Test Database
DB_HOST=localhost
DB_PORT=5433
DB_USER=test
DB_PASSWORD=password
DB_DATABASE=bp_adonis6_test

# Test database (validated by start/env.ts — required even when same as DB_*)
TEST_DB_HOST=localhost
TEST_DB_PORT=5433
TEST_DB_USER=test
TEST_DB_PASSWORD=password
TEST_DB_DATABASE=bp_adonis6_test

# Email — log driver captures emails without sending (no external dependency)
MAIL_DRIVER=log
EMAIL_FROM_ADDRESS=test@example.com
EMAIL_FROM_NAME=Test

# File Uploads (Test config)
UPLOADS_DISK=local
UPLOADS_MAX_SIZE=10485760
UPLOADS_ALLOWED_MIMES=image/*,application/pdf,text/*

# AWS S3 (Optional for tests using local disk)
AWS_ACCESS_KEY_ID=test-key
AWS_SECRET_ACCESS_KEY=test-secret
AWS_REGION=eu-west-1
AWS_BUCKET=test-bucket
AWS_ENDPOINT=

# Stripe Connect (Test credentials)
STRIPE_CONNECT_CLIENT_ID=test_client_id
STRIPE_CONNECT_CLIENT_SECRET=test_client_secret
STRIPE_CONNECT_REDIRECT_URI=http://localhost:3333/admin/integrations/stripe/callback