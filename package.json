    "#abilities/*": "./app/abilities/*.js",
    "#database/*": "./database/*.js",
    "#generated/*": "./.adonisjs/generated/*.js",
    "#transformers/*": "./app/transformers/*.js",
    "#tests/*": "./tests/*.js",
    "#start/*": "./start/*.js",
    "#config/*": "./config/*.js",
    "#inertia/*": "./inertia/*.js"
