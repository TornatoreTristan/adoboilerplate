{
  "name": "adoboilerplate",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "license": "UNLICENSED",
  "scripts": {
    "start": "node bin/server.js",
    "build": "node ace build",
    "dev": "node ace serve --hmr",
    "test": "node ace test",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "email:dev": "email dev --dir inertia/emails"
  },
  "imports": {
    "#users/*": "./app/users/*.ts",
    "#organizations/*": "./app/organizations/*.ts",
    "#admin/*": "./app/admin/*.ts",
    "#sessions/*": "./app/sessions/*.ts",
    "#notifications/*": "./app/notifications/*.ts",
    "#uploads/*": "./app/uploads/*.ts",
    "#shared/*": "./app/shared/*.ts",
    "#auth/*": "./app/auth/*.ts",
    "#roles/*": "./app/roles/*.ts",
    "#mailing/*": "./app/mailing/*.ts",
    "#integrations/*": "./app/integrations/*.ts",
    "#billing/*": "./app/billing/*.ts",
    "#health/*": "./app/health/*.ts",
    "#logs/*": "./app/logs/*.ts",
    "#gdpr/*": "./app/gdpr/*.ts",
    "#audit/*": "./app/audit/*.ts",
    "#monitoring/*": "./app/monitoring/*.ts",
    "#app_settings/*": "./app/app_settings/*.ts",
